# Configurações da API da Binance (Live Trading)
# ATENÇÃO: Nunca comite seu arquivo .env verdadeiro no GitHub!

BINANCE_API_KEY=sua_api_key_aqui
BINANCE_API_SECRET=seu_api_secret_aqui

# Flag opcional para forçar o testnet (se suportado pelo seu setup)
# USE_TESTNET=False

# ── TIER 3: Estratégia XAUT/BTC ──────────────────────────────────────────────
# Pool de BTC separado do saldo BRL — capital medido e acumulado em BTC.
# IMPORTANTE: a Binance exige o quiz Seed Tag para XAUT antes de negociar.

# Total de BTC alocado para a estratégia (ex: 0.01 BTC ≈ R$ 6.000)
XAUT_BTC_CAPITAL=0.01

# BTC investido por posição individual (3 posições = 0.009 BTC usados no máximo)
XAUT_TRADE_SIZE_BTC=0.003

# Número máximo de posições DCA abertas simultaneamente
XAUT_MAX_POSITIONS=3

# Stop Loss por posição: 2% do custo em BTC
XAUT_STOP_LOSS_PCT=0.02

# Take Profit por posição: 4% do custo em BTC
XAUT_TAKE_PROFIT_PCT=0.04
